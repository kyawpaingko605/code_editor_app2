cd /root
# Flutter SDK clone (shallow)
git clone --depth 1 https://github.com/flutter/flutter.git -b stable
# PATH ထည့်
export PATH="$PATH:/root/flutter/bin"
# Flutter doctor
flutter doctor
# Project create
flutter create my_android_app
# Project folder ထဲဝင်
cd my_android_app
